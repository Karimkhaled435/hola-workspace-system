# Firebase Admin SDK Service Account
FIREBASE_SERVICE_ACCOUNT_PATH=./service-account.json
FIREBASE_APP_ID=hola-v20

# Router credentials
ROUTER_HOST=192.168.1.1
ROUTER_USERNAME=admin
ROUTER_PASSWORD=admin
# Set to true ONLY if your router uses a self-signed HTTPS certificate on the LAN
ROUTER_ALLOW_SELF_SIGNED=false

# Server config
PORT=3000
ADMIN_SECRET=hola-server-secret-2026

# CORS allowed origin (your web app URL — no trailing slash)
CORS_ORIGIN=https://your-app.netlify.app
